# Telegram bot — keep secret. Get it from @BotFather.
BOT_TOKEN=

# Optional, recommended for production: a long random string. Telegram sends it
# back in X-Telegram-Bot-Api-Secret-Token header; we'll verify it server-side.
TELEGRAM_SECRET_TOKEN=

# Public URL of the api service on Railway, e.g. https://api-masterby.up.railway.app
PUBLIC_WEB_URL=http://localhost:3000

# Supabase: Settings → API → Project URL and service_role key. NEVER expose
# service_role to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Redis URL for BullMQ (rate-limited Telegram notifications worker).
REDIS_URL=

# Admin panel (Sprint 5). Keep ADMIN_TOKEN secret.
ADMIN_TOKEN=
# Optional: restrict admin access to a single Telegram user ID
ADMIN_TELEGRAM_ID=

# Pino log level. Dev: debug. Prod: info.
LOG_LEVEL=info

# Server port (Railway normally sets this for you).
PORT=3000
