# Telegram bot — keep secret. Get it from @BotFather.
BOT_TOKEN=

# Optional, recommended for production: a long random string. Telegram sends it
# back in X-Telegram-Bot-Api-Secret-Token header; we'll verify it server-side.
TELEGRAM_SECRET_TOKEN=

# Public URL of the frontend (Vercel / Mini App), e.g. https://master-belarus.vercel.app
PUBLIC_WEB_URL=http://localhost:5173

# Public URL of the API itself on Railway, e.g. https://masterbelarus-production-2723.up.railway.app
# Used for Telegram webhook. On Railway you can also use RAILWAY_PUBLIC_DOMAIN.
PUBLIC_API_URL=http://localhost:3000

# Supabase: Settings → API → Project URL, anon key and service_role key. NEVER
# expose service_role to the frontend.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for signing user tokens. Generate via: openssl rand -hex 32
JWT_SECRET=

# Optional: Redis URL for BullMQ (rate-limited Telegram notifications worker).
REDIS_URL=

# Admin panel (Sprint 5). Keep ADMIN_TOKEN secret.
ADMIN_TOKEN=
# Optional: restrict admin access to a single Telegram user ID
ADMIN_TELEGRAM_ID=

# Pino log level. Dev: debug. Prod: info.
LOG_LEVEL=info

# Sentry DSN for error monitoring. Optional. Get from https://sentry.io/settings/projects/
SENTRY_DSN=

# PostHog project API key + host for product analytics. Optional.
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# Server port (Railway normally sets this for you).
PORT=3000
